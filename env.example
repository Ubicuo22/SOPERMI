# Personal Dashboard — variables de entorno
# Copiar a .env y rellenar los valores

# Base de datos SQLite
DB_PATH=./data/dashboard.db

# Auth — PIN de 6 dígitos
# Generar hash: node -e "const b=require('bcryptjs'); console.log(b.hashSync('123456',10))"
AUTH_PIN_HASH=

# JWT para cookies de sesión
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Duración de sesión en segundos (default: 7 días)
SESSION_MAX_AGE=604800

# Pomodoro — duración en minutos (opcional, default en store)
POMODORO_FOCUS_MIN=25
POMODORO_BREAK_MIN=5

# Ambiente
NODE_ENV=production
PORT=3000
ORIGIN=https://dash.ubicuo.icu
